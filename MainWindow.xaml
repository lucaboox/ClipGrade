<Window x:Class="ClipboardApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clipboard App"
        Width="380" Height="470"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Visibility="Hidden">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Tab-style radio button -->
        <Style x:Key="TabRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" CornerRadius="0" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Accent}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgRowHot}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small icon button used inside rows -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource IconColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="0" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgRowHot}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- List row -->
        <Style x:Key="EntryItem" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="b" CornerRadius="0" Background="{DynamicResource BgRow}" Padding="10,8">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgRowHot}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgRowHot}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource Bg}" CornerRadius="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.6" Color="Black"/>
        </Border.Effect>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Clipboard" Foreground="{DynamicResource Fg}"
                       FontSize="15" FontWeight="SemiBold" Margin="2,0,0,8"/>

            <!-- Search -->
            <Border Grid.Row="1" Background="{DynamicResource BgPanel}" CornerRadius="0" Padding="10,0" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🔍  Search…" Foreground="{DynamicResource FgDim}" VerticalAlignment="Center"
                               IsHitTestVisible="False" x:Name="SearchPlaceholder"/>
                    <TextBox Grid.Column="0" x:Name="SearchBox" Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource Fg}" CaretBrush="{DynamicResource Fg}"
                             VerticalContentAlignment="Center" Height="34" FontSize="13"
                             TextChanged="OnSearchChanged"/>
                    <Button Grid.Column="1" x:Name="ClearSearchBtn" Style="{StaticResource IconBtn}"
                            Content="✕" FontSize="12" Width="24" Height="24" Visibility="Collapsed"
                            ToolTip="Clear search" Click="OnClearSearch"/>
                </Grid>
            </Border>

            <!-- Tabs -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                <RadioButton x:Name="TabAll"    Style="{StaticResource TabRadio}" Content="All"    IsChecked="True" Checked="OnTabChanged"/>
                <RadioButton x:Name="TabPinned" Style="{StaticResource TabRadio}" Content="📌 Pinned" Checked="OnTabChanged"/>
                <RadioButton x:Name="TabImages" Style="{StaticResource TabRadio}" Content="🖼 Images"  Checked="OnTabChanged"/>
            </StackPanel>

            <!-- List -->
            <Grid Grid.Row="3">
                <ListBox x:Name="List"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="False"
                         ItemContainerStyle="{StaticResource EntryItem}"
                         PreviewMouseLeftButtonDown="OnListPreviewMouseDown"
                         MouseDoubleClick="OnItemDoubleClick"
                         ContextMenuOpening="OnListContextMenuOpening">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Background="Transparent">
                                <Grid.ContextMenu>
                                    <ContextMenu Opened="OnCtxOpened" Closed="OnCtxClosed">
                                        <MenuItem Header="Paste" Click="OnMenuPaste"/>
                                        <MenuItem Header="Copy" Click="OnMenuCopy"/>
                                        <MenuItem Header="{Binding PinMenuText}" Click="OnPinClick"/>
                                        <Separator/>
                                        <MenuItem Header="Delete" Click="OnDeleteClick"/>
                                    </ContextMenu>
                                </Grid.ContextMenu>

                                <TextBlock Text="{Binding DisplayText}" Foreground="{DynamicResource Fg}"
                                           TextWrapping="Wrap" MaxHeight="60" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" FontSize="13"
                                           Visibility="{Binding IsText, Converter={StaticResource BoolToVis}}"
                                           x:Name="TextPreview"
                                           ToolTipService.InitialShowDelay="600" ToolTipService.BetweenShowDelay="0">
                                    <TextBlock.ToolTip>
                                        <ToolTip>
                                            <TextBlock Text="{Binding FullText}" TextWrapping="Wrap" FontSize="12"/>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>

                                <Image Source="{Binding Thumbnail}" MaxHeight="90" MaxWidth="300"
                                       HorizontalAlignment="Left" Stretch="Uniform"
                                       Visibility="{Binding IsImage, Converter={StaticResource BoolToVis}}"
                                       x:Name="ImgPreview"
                                       ToolTipService.InitialShowDelay="600" ToolTipService.BetweenShowDelay="0">
                                    <Image.ToolTip>
                                        <ToolTip>
                                            <Image Source="{Binding Preview}" MaxWidth="480" MaxHeight="360" Stretch="Uniform"/>
                                        </ToolTip>
                                    </Image.ToolTip>
                                </Image>

                                <!-- Pin marker shown on pinned rows -->
                                <Path Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Right" VerticalAlignment="Top"
                                      Fill="{DynamicResource IconColor}"
                                      Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}"
                                      Data="M16,9 V4 h1 c.55,0 1,-.45 1,-1 s-.45,-1 -1,-1 H7 c-.55,0 -1,.45 -1,1 s.45,1 1,1 h1 v5 c0,1.66 -1.34,3 -3,3 v2 h5.97 v7 l1,1 1,-1 v-7 H19 v-2 c-1.66,0 -3,-1.34 -3,-3 z"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock x:Name="EmptyState"
                           Foreground="{DynamicResource FgDim}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="24"
                           Visibility="Collapsed"/>
            </Grid>
        </Grid>
    </Border>
</Window>
